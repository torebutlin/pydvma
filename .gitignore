pydvma.egg-info/

# Staged browser UI for the wheel: `scripts/stage_webui.py` mirrors
# `webui/dist` here so `pydvma-serve` works from a pip install. It is a
# build artefact (rebuilt from webui/), never committed. A transient
# `pydvma/_webui.__lean_hidden__` may appear if a lean build is
# interrupted (see _pydvma_build.py); ignore it too.
pydvma/_webui/
pydvma/_webui.__lean_hidden__/
.spyproject/
example.log

#find . -name '.DS_Store' -type f -delete
.DS_Store
pydvma_template_with anim.ipynb

# Documentation builds
site/
.cache/

# Claude Code: per-machine workspace (worktrees, transient state).
# Note: CLAUDE.md itself is tracked — it's the session-level rules for
# anyone working with Claude on this repo. Personal per-machine
# overrides go in CLAUDE.local.md, which stays gitignored.
.claude/
CLAUDE.local.md

# JupyterLite build artefacts (wheels dropped in by CI / local builds)
lite/pypi/
lite/.jupyterlite.doit.db
_lite_build/

# Scratch data files from local lite testing (not source)
lite/content/*.dvma

# webui (Svelte + Vite web GUI)
webui/node_modules/
webui/dist/
webui/public/pyodide/
webui/public/pypi/
webui/test-results/
webui/playwright-report/
